rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check user role
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Helper function to check if user is admin or responder
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'responder']
      );
    }

    // Users collection
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isOwner(userId);
      
      // Admins can read all users
      allow read: if isAdmin();
    }

    // Incidents collection
    match /incidents/{incidentId} {
      // Authenticated users can read incidents
      allow read: if isAuthenticated();
      
      // Users can create incidents (submitted status)
      allow create: if isAuthenticated() && 
                       request.resource.data.reportedBy == request.auth.uid &&
                       request.resource.data.status == 'submitted';
      
      // Admins can update incidents
      // Reporters can also update their own incidents (used to attach images, etc.)
      allow update: if isAdmin() || (
        isAuthenticated() &&
        resource.data.reportedBy == request.auth.uid
      );
      
      // Admins can delete incidents
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isOwner(resource.data.userId);
      
      // System (backend) can write notifications
      allow write: if request.auth == null || isAdmin();
    }

    // Incident updates subcollection
    match /incidents/{incidentId}/updates/{updateId} {
      // Public read access for incident updates
      allow read: if true;
      
      // Authenticated users can create updates if they own the incident or are admin
      allow create: if isAuthenticated();
      
      // Only admins can update/delete
      allow update, delete: if isAdmin();
    }
  }
}